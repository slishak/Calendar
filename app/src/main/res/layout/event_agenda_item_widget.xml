<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/event_agenda_item_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="4dp"
    android:paddingTop="4dp"
    android:paddingEnd="6dp"
    android:paddingBottom="4dp">

    <!-- Coloured left bar -->
    <ImageView
        android:id="@+id/event_agenda_color_bar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_alignTop="@+id/event_agenda_title"
        android:layout_alignBottom="@+id/event_agenda_details_row"
        android:layout_marginEnd="6dp"
        android:background="@drawable/event_list_color_bar"
        android:scaleType="fitXY" />

    <!-- Task icon (shown only for tasks) -->
    <ImageView
        android:id="@+id/event_agenda_task_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/event_agenda_title"
        android:layout_alignBottom="@+id/event_agenda_title"
        android:layout_marginStart="8dp"
        android:layout_toEndOf="@id/event_agenda_color_bar"
        android:src="@drawable/ic_task_vector" />

    <!-- Event title -->
    <TextView
        android:id="@+id/event_agenda_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/event_agenda_task_image"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:paddingEnd="2dp"
        android:textSize="@dimen/day_text_size"
        tools:text="Event title" />

    <!-- Date (bold) · time · location on one row -->
    <LinearLayout
        android:id="@+id/event_agenda_details_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/event_agenda_title"
        android:layout_marginStart="8dp"
        android:layout_toEndOf="@id/event_agenda_color_bar"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/event_agenda_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.8"
            android:includeFontPadding="false"
            android:textSize="@dimen/normal_text_size"
            android:textStyle="bold"
            tools:text="26 Mar" />

        <TextView
            android:id="@+id/event_agenda_time_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.8"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingEnd="2dp"
            android:textSize="@dimen/normal_text_size"
            tools:text="  09:00 – 12:00  Location" />

    </LinearLayout>

</RelativeLayout>
