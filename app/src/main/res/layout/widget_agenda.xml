<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_agenda_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_round_background" />

    <!-- Left date strip: day name, large day number, month name -->
    <RelativeLayout
        android:id="@+id/widget_agenda_date_strip"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:minWidth="56dp"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/widget_agenda_date_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_agenda_day_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_agenda_day_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:lineSpacingMultiplier="0.85"
                android:textSize="36sp" />

            <TextView
                android:id="@+id/widget_agenda_month_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textSize="11sp" />

        </LinearLayout>

    </RelativeLayout>

    <!-- Thin vertical divider after date strip -->
    <ImageView
        android:id="@+id/widget_agenda_divider"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@id/widget_agenda_date_strip"
        android:background="#33FFFFFF" />

    <!-- Right action buttons panel -->
    <LinearLayout
        android:id="@+id/widget_agenda_actions"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="6dp">

        <ImageView
            android:id="@+id/widget_agenda_go_to_today"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginBottom="8dp" />

        <ImageView
            android:id="@+id/widget_agenda_new_event"
            android:layout_width="24dp"
            android:layout_height="24dp" />

    </LinearLayout>

    <!-- Events list -->
    <ListView
        android:id="@+id/widget_agenda_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@id/widget_agenda_divider"
        android:layout_toStartOf="@id/widget_agenda_actions"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/widget_agenda_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentTop="true"
        android:layout_toEndOf="@id/widget_agenda_divider"
        android:layout_toStartOf="@id/widget_agenda_actions"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="@string/no_upcoming_events" />

</RelativeLayout>
